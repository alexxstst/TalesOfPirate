<?xml version="1.0" encoding="utf-8" ?>
<nlog xmlns="http://www.nlog-project.org/schemas/NLog.xsd"
      xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      autoReload="true">

  <targets async="true">
    <target name="console"
            xsi:type="ColoredConsole"
            layout="[${date:format=HH\:mm\:ss} ${level:uppercase=true:padding=-5}] ${message}${onexception:inner=${newline}${exception:format=tostring}}" />

    <target name="file"
            xsi:type="File"
            fileName="${basedir}/logs/${shortdate}.log"
            layout="[${date:format=HH\:mm\:ss} ${level:uppercase=true:padding=-5}] ${message}${onexception:inner=${newline}${exception:format=tostring}}"
            archiveAboveSize="10485760"
            maxArchiveFiles="30" />
  </targets>

  <rules>
    <logger name="Microsoft.*" minlevel="Warn" writeTo="console,file" final="true" />
    <logger name="System.*" minlevel="Warn" writeTo="console,file" final="true" />
    <logger name="*" minlevel="Trace" writeTo="console,file" />
  </rules>

</nlog>
